<%- include('header') %>

<div class="container my-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-dark py-4 text-center">
                    <div class="mb-3">
                        <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 100px; height: 100px;">
                            <i class="bi bi-person-fill text-dark fs-1"></i>
                        </div>
                    </div>
                    <h3 class="text-white fw-bold mb-0">My Profile</h3>
                    <p class="text-white-50 small mb-0">Manage your personal information</p>
                </div>
                <div class="card-body p-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold mb-1">Username</label>
                            <div class="p-3 bg-light rounded-3 border">
                                <span class="fw-semibold text-dark"><%= user.username %></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold mb-1">Email Address</label>
                            <div class="p-3 bg-light rounded-3 border">
                                <span class="fw-semibold text-dark"><%= user.email %></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold mb-1">Role</label>
                            <div class="p-3 bg-light rounded-3 border">
                                <span class="badge bg-dark px-3 py-2 rounded-pill"><%= user.role %></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="small text-muted text-uppercase fw-bold mb-1">Member Since</label>
                            <div class="p-3 bg-light rounded-3 border">
                                <span class="fw-semibold text-dark"><%= user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A' %></span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex gap-3 justify-content-center">
                        <a href="/" class="btn btn-outline-dark px-4 py-2 rounded-3 fw-bold">
                            <i class="bi bi-arrow-left me-2"></i> Back to Shop
                        </a>
                        <button class="btn btn-dark px-4 py-2 rounded-3 fw-bold" onclick="alert('Update Profile functionality coming soon!')">
                            <i class="bi bi-pencil-square me-2"></i> Edit Profile
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('footer') %>
