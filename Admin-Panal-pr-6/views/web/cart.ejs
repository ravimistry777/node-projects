<%- include('header') %>

<div class="container my-5" style="min-height: 60vh;">
    <h2 class="fw-bold mb-4">Shopping Cart</h2>

    <% if (cartItems && cartItems.length > 0) { %>
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="border-0 p-3">Product</th>
                                        <th class="border-0 p-3 text-center">Quantity</th>
                                        <th class="border-0 p-3 text-end">Price</th>
                                        <th class="border-0 p-3 text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% cartItems.forEach(item => { %>
                                        <tr>
                                            <td class="p-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="<%= item.image %>" alt="<%= item.name %>" class="rounded me-3" style="width: 60px; height: 60px; object-fit: cover;">
                                                    <div>
                                                        <h6 class="mb-0 fw-bold"><%= item.name %></h6>
                                                        <small class="text-muted">Size: <span class="badge bg-light text-dark border"><%= item.size %></span></small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="p-3 text-center">
                                                <div class="d-flex align-items-center justify-content-center gap-2">
                                                    <a href="/cart/update/<%= item.id %>/dec?size=<%= encodeURIComponent(item.size) %>" class="btn btn-sm btn-outline-dark px-2 py-0">-</a>
                                                    <span class="badge bg-light text-dark border px-3 py-2"><%= item.quantity %></span>
                                                    <a href="/cart/update/<%= item.id %>/inc?size=<%= encodeURIComponent(item.size) %>" class="btn btn-sm btn-outline-dark px-2 py-0">+</a>
                                                </div>
                                            </td>
                                            <td class="p-3 text-end">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></td>
                                            <td class="p-3 text-end">
                                                <a href="/cart/remove/<%= item.id %>?size=<%= encodeURIComponent(item.size) %>" class="text-danger"><i class="bi bi-trash"></i></a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal</span>
                            <span>₹<%= total %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Shipping</span>
                            <span class="text-success">Free</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold">Total</span>
                            <span class="fw-bold fs-5">₹<%= total %></span>
                        </div>
                        <button class="btn btn-dark w-100 py-3 fw-bold">Proceed to Checkout</button>
                        <div class="mt-3 text-center">
                            <a href="/" class="text-muted small text-decoration-none">Continue Shopping</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="bi bi-bag-x fs-1 text-muted mb-3 d-block"></i>
            <h3>Your cart is empty</h3>
            <p class="text-muted">Looks like you haven't added anything to your cart yet.</p>
            <a href="/" class="btn btn-dark mt-3">Start Shopping</a>
        </div>
    <% } %>
</div>

<%- include('footer') %>
