<%- include('header') %>

<div class="container py-5">
    <!-- Hero Banner -->
    <div class="rounded-4 text-white p-5 mb-5 overflow-hidden position-relative d-flex align-items-center" 
         style="background: linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2)), url('https://images.unsplash.com/photo-1502163140606-888448ae8cfe?q=80&w=1920&auto=format&fit=crop') center/cover no-repeat; min-height: 400px;">
        <div class="position-relative z-1 p-md-3">
            <h1 class="display-3 fw-bold mb-3">Summer Collection 2026</h1>
            <p class="lead mb-4 fw-medium fs-4 text-shadow">Breezy styles for your perfect beach days.</p>
            <a href="#products" class="btn btn-light px-5 py-3 fw-bold rounded-pill shadow-sm">Shop Now</a>
        </div>
    </div>

    <!-- Filters & Sorting -->
    <div id="products" class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <h4 class="fw-bold mb-0">Featured Products</h4>
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button class="btn btn-white border dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    Sort by: <%= query.sort === 'priceLow' ? 'Price: Low to High' : (query.sort === 'priceHigh' ? 'Price: High to Low' : 'Latest') %>
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="/?sort=latest">Latest</a></li>
                    <li><a class="dropdown-item" href="/?sort=priceLow">Price: Low to High</a></li>
                    <li><a class="dropdown-item" href="/?sort=priceHigh">Price: High to Low</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="row g-4 mb-5">
        <% if (products && products.length > 0) { %>
            <% products.forEach(product => { %>
                <div class="col-sm-6 col-md-4">
                    <div class="product-card-web shadow-sm h-100 d-flex flex-column position-relative cursor-pointer" onclick="window.location.href='/product-details/<%= product._id %>'" style="cursor: pointer; transition: transform 0.2s;">
                        <div class="position-relative">
                            <img src="<%= product.productImage %>" class="card-img-top" alt="<%= product.productName %>" style="height: 320px; object-fit: cover;">
                            <% if (product.productStock <= 5 && product.productStock > 0) { %>
                                <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark badge-stock">Only <%= product.productStock %> left</span>
                            <% } else if (product.productStock == 0) { %>
                                <span class="position-absolute top-0 end-0 m-3 badge bg-danger text-white badge-stock">Out of Stock</span>
                            <% } %>
                        </div>
                        <div class="card-body p-4 d-flex flex-column">
                            <p class="text-muted small mb-1"><%= product.categoryId.categoryName %></p>
                            <h6 class="fw-bold mb-2 text-truncate" title="<%= product.productName %>"><%= product.productName %></h6>
                            <div class="mt-auto">
                      <h5 class="fw-bold mb-3">₹<%= product.productPrice %></h5>
                      <div class="d-grid gap-2" onclick="event.stopPropagation();">
                        <a href="/product-details/<%= product._id %>" class="btn btn-outline-dark btn-sm">View Details</a>
                        <a href="/add-to-cart/<%= product._id %>" class="btn btn-dark btn-sm <%= product.productStock == 0 ? 'disabled' : '' %>">
                          <i class="bi bi-cart-plus me-2"></i>Add to Cart
                        </a>
                      </div>
                    </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <i class="bi bi-search fs-1 text-muted mb-3 d-block"></i>
                <h5>No products found</h5>
                <p class="text-muted">Try adjusting your filters or search terms.</p>
                <a href="/" class="btn btn-dark">Clear All Filters</a>
            </div>
        <% } %>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
        <nav aria-label="Product pagination" class="d-flex justify-content-center mt-5">
            <ul class="pagination pagination-lg">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                    <a class="page-link border-0 rounded-3 me-2 bg-light text-dark" href="/?page=<%= currentPage - 1 %><%= query.search ? '&search=' + query.search : '' %><%= query.category ? '&category=' + query.category : '' %><%= query.subcategory ? '&subcategory=' + query.subcategory : '' %><%= query.extracategory ? '&extracategory=' + query.extracategory : '' %><%= query.sort ? '&sort=' + query.sort : '' %>">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link border-0 rounded-3 mx-1 <%= currentPage === i ? 'bg-dark text-white' : 'bg-light text-dark' %>" href="/?page=<%= i %><%= query.search ? '&search=' + query.search : '' %><%= query.category ? '&category=' + query.category : '' %><%= query.subcategory ? '&subcategory=' + query.subcategory : '' %><%= query.extracategory ? '&extracategory=' + query.extracategory : '' %><%= query.sort ? '&sort=' + query.sort : '' %>">
                            <%= i %>
                        </a>
                    </li>
                <% } %>

                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                    <a class="page-link border-0 rounded-3 ms-2 bg-light text-dark" href="/?page=<%= currentPage + 1 %><%= query.search ? '&search=' + query.search : '' %><%= query.category ? '&category=' + query.category : '' %><%= query.subcategory ? '&subcategory=' + query.subcategory : '' %><%= query.extracategory ? '&extracategory=' + query.extracategory : '' %><%= query.sort ? '&sort=' + query.sort : '' %>">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    <% } %>
</div>

<%- include('footer') %>
