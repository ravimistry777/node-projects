<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SaaSStore | Online Shopping</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/1170/1170678.png" />

    <style>
        :root {
            --bg-body: #fafaf9;
            --text-main: #292524;
            --primary: #1c1917;
            --border-light: #e7e5e4;
            --radius-lg: 12px;
        }
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
        }
        .navbar-web {
            background: white;
            border-bottom: 1px solid var(--border-light);
            padding: 1rem 0;
        }
        .nav-link-web {
            position: relative;
            font-weight: 500;
            color: var(--text-main);
            padding: 0.5rem 1rem !important;
            background-image: linear-gradient(var(--primary), var(--primary));
            background-position: left bottom;
            background-repeat: no-repeat;
            background-size: 0 2px;
            transition: color 0.2s ease, background-size 0.25s ease;
        }
        .nav-link-web:hover,
        .nav-link-web:focus,
        .nav-item.dropdown:hover > .nav-link-web,
        .nav-item.dropdown .nav-link-web.show {
            color: var(--primary);
            background-size: 100% 2px;
        }
        .dropdown-menu-web {
            border: 1px solid rgba(0,0,0,0.05);
            border-radius: 16px;
            padding: 0.5rem;
            min-width: 240px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            background-color: #fff;
            margin-top: 0;
        }
        .dropdown-menu-web .dropdown-item {
            font-size: 0.95rem;
            padding: 0.6rem 1rem;
            border-radius: 8px;
            color: #4b5563;
            transition: all 0.2s;
        }
        .dropdown-menu-web .dropdown-item.fw-bold {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #9ca3af;
            margin-bottom: 0.25rem;
        }
        .dropdown-menu-web .dropdown-item:hover {
            background-color: #f3f4f6;
            color: var(--primary);
            transform: translateX(3px);
        }
        
        /* Nested Dropdown CSS */
        .dropdown-menu li { position: relative; }
    /* Hide all default Bootstrap dropdown arrows */
    .dropdown-toggle::after, 
    .dropend .dropdown-toggle::after, 
    .dropend > .dropdown-item::after {
        display: none !important;
    }

        .alert-dark {
            background-color: #1c1917;
            color: white;
        }
        .btn-close-white {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
        .product-card-web {
            border: none;
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: transform 0.2s;
            background: white;
        }
        .product-card-web:hover {
            transform: translateY(-5px);
        }
        .badge-stock {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Animation Keyframes */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (min-width: 992px) {
            /* Main Dropdown Positioning & Bridge */
            .navbar-web .dropdown-menu-web {
                margin-top: 0.5rem;
                display: none;
            }
            /* Bridge for Main Dropdown */
            .navbar-web .dropdown-menu-web::before {
                content: '';
                position: absolute;
                top: -10px;
                left: 0;
                width: 100%;
                height: 10px;
                background: transparent;
            }

            .navbar-web .dropdown.show .dropdown-menu-web {
                display: block;
                animation: fadeInUp 0.2s ease forwards;
            }

            /* Nested Dropdown Positioning */
            .navbar-web .dropdown-menu-web .dropend > .dropdown-menu {
                top: -0.5rem;
                left: 100%;
                margin-left: 0.25rem;
                display: none;
                box-shadow: 0 10px 40px rgba(0,0,0,0.1);
                border-radius: 16px;
                border: 1px solid rgba(0,0,0,0.05);
                min-width: 220px;
                padding: 0.5rem;
            }
            
            /* Bridge for Nested Dropdown */
            .navbar-web .dropend::after {
                content: '';
                position: absolute;
                top: 0;
                right: -10px;
                height: 100%;
                width: 20px;
                background: transparent;
            }

            .navbar-web .dropdown-menu-web .dropend:hover > .dropdown-menu {
                display: block;
                animation: fadeInUp 0.2s ease forwards;
            }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-web sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold fs-4" href="/">SaaS<span class="text-muted">Store</span></a>
      
      <!-- Flash Messages -->
      <div class="position-fixed top-0 start-50 translate-middle-x mt-3 z-3" style="width: auto; min-width: 300px;">
        <% if(typeof success !== 'undefined' && success && success.length > 0) { %>
            <div class="alert alert-dark alert-dismissible fade show shadow-lg border-0 mb-2" role="alert">
              <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2"></i>
                <div><%= success %></div>
              </div>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if(typeof error !== 'undefined' && error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show shadow-lg border-0 mb-2" role="alert">
              <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div><%= error %></div>
              </div>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
      </div>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <% categories.forEach(cat => { %>
            <li class="nav-item dropdown">
              <a class="nav-link nav-link-web dropdown-toggle" href="/?category=<%= cat._id %>" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <%= cat.categoryName %>
              </a>
              <ul class="dropdown-menu dropdown-menu-web shadow">
                <li><a class="dropdown-item py-2 fw-bold" href="/?category=<%= cat._id %>">All <%= cat.categoryName %></a></li>
                <li><hr class="dropdown-divider"></li>
                <% subcategories.filter(sub => sub.categoryId._id.toString() === cat._id.toString()).forEach(sub => { %>
                  <li class="dropend">
                    <a class="dropdown-item d-flex justify-content-between align-items-center" href="/?subcategory=<%= sub._id %>">
                      <%= sub.subCategoryName %> <i class="bi bi-chevron-right small ms-2"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-web shadow">
                      <li><a class="dropdown-item fw-bold text-uppercase" href="/?subcategory=<%= sub._id %>">All <%= sub.subCategoryName %></a></li>
                      <% extracategories.filter(ex => ex.subCategoryId._id.toString() === sub._id.toString()).forEach(extra => { %>
                        <li><a class="dropdown-item" href="/?extracategory=<%= extra._id %>"><%= extra.extraCategoryName %></a></li>
                      <% }) %>
                    </ul>
                  </li>
                <% }) %>
              </ul>
            </li>
          <% }) %>
        </ul>
            
            <form class="d-flex me-3" action="/" method="GET">
                <div class="input-group">
                    <input class="form-control border-end-0 bg-light border-0" type="search" name="search" placeholder="Search products..." value="<%= typeof query !== 'undefined' ? query.search : '' %>">
                    <button class="btn btn-light border-start-0 border-0" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>

            <div class="d-flex align-items-center gap-3">
                <a href="/cart" class="text-dark position-relative">
                    <i class="bi bi-bag fs-5"></i>
                    <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark" style="font-size: 0.6rem;">
                            <%= cartCount %>
                        </span>
                    <% } %>
                </a>
                
                <% if (typeof user !== 'undefined' && user && user.role === 'customer') { %>
                    <div class="dropdown">
                        <button class="btn btn-outline-dark btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Hi, <%= user.username %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/profile">My Profile</a></li>
                            <li><a class="dropdown-item" href="/orders">My Orders</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
                        </ul>
                    </div>
                <% } else { %>
                    <a href="/login" class="btn btn-dark btn-sm px-3">Login</a>
                <% } %>
                
                <a href="/admin" class="btn btn-outline-secondary btn-sm" title="Admin Panel">
                    <i class="bi bi-person-gear"></i> Admin
                </a>
            </div>
        </div>
    </div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var dropdowns = document.querySelectorAll('.navbar-web .dropdown');

        dropdowns.forEach(function (dropdown) {
            var toggle = dropdown.querySelector('.dropdown-toggle');
            var menu = dropdown.querySelector('.dropdown-menu-web');
            if (!toggle || !menu) return;

            var hideTimeout;

            function showMenu() {
                if (window.innerWidth < 992) return;
                clearTimeout(hideTimeout);
                dropdown.classList.add('show');
                menu.classList.add('show');
            }

            function hideMenu() {
                if (window.innerWidth < 992) return;
                hideTimeout = setTimeout(function () {
                    dropdown.classList.remove('show');
                    menu.classList.remove('show');
                }, 160);
            }

            dropdown.addEventListener('mouseenter', showMenu);
            dropdown.addEventListener('mouseleave', hideMenu);
            menu.addEventListener('mouseenter', showMenu);
            menu.addEventListener('mouseleave', hideMenu);
        });
    });
</script>
